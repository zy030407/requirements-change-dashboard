PORT=4000
NODE_ENV=development
SESSION_SECRET=replace-with-long-random-secret
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/requirements_wiki
REDIS_URL=redis://localhost:6379
JOB_QUEUE_PROVIDER=inline
JOB_QUEUE_PROCESS_IN_API=true
INGEST_WORKER_CONCURRENCY=2
OPENAI_API_KEY=
OPENAI_TEXT_MODEL=gpt-4.1-mini
OPENAI_TRANSCRIBE_MODEL=gpt-4o-transcribe
STORAGE_PROVIDER=local
UPLOAD_DIR=uploads
DATA_DIR=data

# 阿里云 OSS（生产环境 STORAGE_PROVIDER=oss）
ALI_OSS_REGION=oss-cn-hangzhou
ALI_OSS_BUCKET=
ALI_OSS_ENDPOINT=
ALI_OSS_ACCESS_KEY_ID=
ALI_OSS_ACCESS_KEY_SECRET=
ALI_OSS_STS_ROLE_ARN=
ALI_OSS_PRIVATE_URL_TTL_SECONDS=900
ALI_OSS_SECURE=true
