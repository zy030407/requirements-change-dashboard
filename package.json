{
  "name": "requirements-change-dashboard",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:client\"",
    "dev:client": "vite --host 0.0.0.0",
    "dev:server": "node server/index.js",
    "build": "vite build",
    "preview": "vite preview --host 0.0.0.0",
    "start": "node server/index.js",
    "start:worker": "node server/worker.js",
    "smoke": "node server/smoke-test.js",
    "prisma:validate": "prisma validate",
    "prisma:migrate": "prisma migrate deploy",
    "migrate:json": "node server/migrate-json-to-prisma.js"
  },
  "dependencies": {
    "@prisma/client": "^7.8.0",
    "@vitejs/plugin-react": "^5.0.4",
    "ali-oss": "^6.23.0",
    "bullmq": "^5.76.4",
    "concurrently": "^9.2.1",
    "cors": "^2.8.6",
    "d3": "^7.9.0",
    "dotenv": "^17.4.2",
    "exceljs": "^4.4.0",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "lucide-react": "^0.468.0",
    "mammoth": "^1.12.0",
    "markdown-it": "^14.1.1",
    "mermaid": "^11.14.0",
    "multer": "^2.1.1",
    "openai": "^6.35.0",
    "pdf-parse": "^2.4.5",
    "postgres": "^3.4.7",
    "prisma": "^7.8.0",
    "react": "^19.1.1",
    "react-dom": "^19.1.1",
    "recharts": "^3.2.1",
    "vite": "^7.1.12"
  }
}
